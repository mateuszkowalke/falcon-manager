generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Todo {
  uid        String  @id @default(cuid())
  created_at DateTime
  text       String
  done       Boolean
}

model addresses {
  id                                Int               @id @default(autoincrement())
  street                            String
  no                                String
  zip_code                          String
  city                              String
  country                           String
  owner_id                          Int
  breeding_project_id               Int
  breeding_projects                 breeding_projects @relation(fields: [breeding_project_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users_addresses_owner_idTousers   users             @relation("addresses_owner_idTousers", fields: [owner_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  offices                           offices[]
  users_addressesTousers_address_id users[]           @relation("addressesTousers_address_id")
}

model aviaries {
  id                  Int               @id @default(autoincrement())
  name                String
  capacity            String
  last_cleaned        DateTime
  created_at          DateTime
  updated_at          DateTime
  breeding_project_id Int
  breeding_projects   breeding_projects @relation(fields: [breeding_project_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  falcons             falcons[]
}

model birth_certs {
  id         Int         @id @default(autoincrement())
  scan_file  String
  raw_file   String
  office_id  Int
  created_at DateTime
  updated_at DateTime
  offices    offices     @relation(fields: [office_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  documents  documents[]
}

model breeding_projects {
  id                      Int                       @id @default(autoincrement())
  name                    String
  vet_reg_no              String
  owner_id                Int
  created_at              DateTime
  updated_at              DateTime
  users                   users                     @relation(fields: [owner_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  addresses               addresses[]
  aviaries                aviaries[]
  falcons                 falcons[]
  offices                 offices[]
  users_breeding_projects users_breeding_projects[]
}

model cites {
  id         Int         @id @default(autoincrement())
  scan_file  String
  raw_file   String
  office_id  Int
  created_at DateTime
  updated_at DateTime
  offices    offices     @relation(fields: [office_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  documents  documents[]
}

model documents {
  id              Int           @id @default(autoincrement())
  falcon_id       Int
  birth_cert_id   Int
  cites_id        Int
  registration_id Int
  birth_certs     birth_certs   @relation(fields: [birth_cert_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  cites           cites         @relation(fields: [cites_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  falcons         falcons       @relation(fields: [falcon_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  registrations   registrations @relation(fields: [registration_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model falcons {
  id                                    Int               @id @default(autoincrement())
  name                                  String
  ring                                  String
  species_id                            Int
  sex_id                                Int
  birth_date                            DateTime
  source                                String
  aviary_id                             Int
  father                                Int
  mother                                Int
  width_young                           Int
  length_young                          Int
  weight_young                          Int
  width_old                             Int
  length_old                            Int
  weight_old                            Int
  notes                                 String
  created_at                            DateTime
  updated_at                            DateTime
  breeding_project_id                   Int
  sex                                   sex               @relation(fields: [sex_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  aviaries                              aviaries          @relation(fields: [aviary_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  breeding_projects                     breeding_projects @relation(fields: [breeding_project_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  falcons_falconsTofalcons_father       falcons           @relation("falconsTofalcons_father", fields: [father], references: [id], onDelete: NoAction, onUpdate: NoAction)
  falcons_falconsTofalcons_mother       falcons           @relation("falconsTofalcons_mother", fields: [mother], references: [id], onDelete: NoAction, onUpdate: NoAction)
  species                               species           @relation(fields: [species_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  documents                             documents[]
  other_falcons_falconsTofalcons_father falcons[]         @relation("falconsTofalcons_father")
  other_falcons_falconsTofalcons_mother falcons[]         @relation("falconsTofalcons_mother")
  pairs_falconsTopairs_female_id        pairs[]           @relation("falconsTopairs_female_id")
  pairs_falconsTopairs_male_id          pairs[]           @relation("falconsTopairs_male_id")
  photos                                photos[]
}

model office_types {
  id      Int       @id @default(autoincrement())
  name    String
  offices offices[]
}

model offices {
  id                  Int               @id @default(autoincrement())
  name                String
  office_type_id      Int
  address_id          Int
  breeding_project_id Int
  addresses           addresses         @relation(fields: [address_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  breeding_projects   breeding_projects @relation(fields: [breeding_project_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  office_types        office_types      @relation(fields: [office_type_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  birth_certs         birth_certs[]
  cites               cites[]
  registrations       registrations[]
}

model pairs {
  id                               Int      @id @default(autoincrement())
  name                             String
  male_id                          Int
  female_id                        Int
  created_at                       DateTime
  updated_at                       DateTime
  falcons_falconsTopairs_female_id falcons  @relation("falconsTopairs_female_id", fields: [female_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  falcons_falconsTopairs_male_id   falcons  @relation("falconsTopairs_male_id", fields: [male_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model permissions {
  id                Int                 @id @default(autoincrement())
  name              String
  roles_permissions roles_permissions[]
}

model photos {
  id        Int     @id @default(autoincrement())
  falcon_id Int
  file      String
  falcons   falcons @relation(fields: [falcon_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model registrations {
  id         Int         @id @default(autoincrement())
  scan_file  String
  raw_file   String
  office_id  Int
  created_at DateTime
  updated_at DateTime
  offices    offices     @relation(fields: [office_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  documents  documents[]
}

model roles {
  id                Int                 @id @default(autoincrement())
  name              String
  roles_permissions roles_permissions[]
  users             users[]
}

model roles_permissions {
  id            Int         @id @default(autoincrement())
  role_id       Int
  permission_id Int
  permissions   permissions @relation(fields: [permission_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  roles         roles       @relation(fields: [role_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model species {
  id      Int       @id @default(autoincrement())
  name    String
  latin   String
  falcons falcons[]
}

model users {
  id                                    Int                       @id @default(autoincrement())
  email                                 String
  name                                  String
  password                              String
  address_id                            Int
  photo_file                            String
  role                                  Int
  created_at                            DateTime
  updated_at                            DateTime
  addresses_addressesTousers_address_id addresses                 @relation("addressesTousers_address_id", fields: [address_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  roles                                 roles                     @relation(fields: [role], references: [id], onDelete: NoAction, onUpdate: NoAction)
  addresses_addresses_owner_idTousers   addresses[]               @relation("addresses_owner_idTousers")
  breeding_projects                     breeding_projects[]
  users_breeding_projects               users_breeding_projects[]
}

model users_breeding_projects {
  id                  Int               @id @default(autoincrement())
  user_id             Int
  breeding_project_id Int
  breeding_projects   breeding_projects @relation(fields: [breeding_project_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users               users             @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model sex {
  id      Int       @id @default(autoincrement())
  name    String
  falcons falcons[]
}
