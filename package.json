{
	"name": "falcon-manager",
	"version": "0.0.1",
	"scripts": {
		"dev": "svelte-kit dev",
		"build": "svelte-kit build",
		"package": "svelte-kit package",
		"preview": "svelte-kit preview",
		"check": "svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --ignore-path .gitignore --check --plugin-search-dir=. . && eslint --ignore-path .gitignore .",
		"format": "prettier --ignore-path .gitignore --write --plugin-search-dir=. .",
        "db-seed": "tsc prisma/seed.ts prisma/seeds/* && node prisma/seed.js && rm prisma/seed.js && rm prisma/seeds/*.js"
	},
	"devDependencies": {
		"@sveltejs/adapter-auto": "next",
		"@types/bcrypt": "^5.0.0",
		"@types/cookie": "^0.4.1",
		"@types/jsonwebtoken": "^8.5.6",
		"@types/node": "14",
		"@typescript-eslint/eslint-plugin": "^4.31.1",
		"@typescript-eslint/parser": "^4.31.1",
		"eslint": "^7.32.0",
		"eslint-config-prettier": "^8.3.0",
		"eslint-plugin-svelte3": "^3.2.1",
		"prettier": "^2.4.1",
		"prettier-plugin-svelte": "^2.4.0",
		"prisma": "^3.6.0",
		"svelte": "^3.44.0",
		"svelte-check": "^2.2.6",
		"svelte-preprocess": "^4.9.4",
		"ts-node": "^10.4.0",
		"tslib": "^2.3.1",
		"typescript": "^4.4.3"
	},
	"type": "module",
	"dependencies": {
		"@fontsource/fira-mono": "^4.5.0",
		"@lukeed/uuid": "^2.0.0",
		"@prisma/client": "^3.7.0",
		"@sveltejs/adapter-node": "^1.0.0-next.60",
		"@sveltejs/kit": "^1.0.0-next.216",
		"bcrypt": "^5.0.1",
		"cookie": "^0.4.1",
		"dotenv": "^10.0.0",
		"jsonwebtoken": "^8.5.1"
	},
	"prisma": {
		"seed": "node --loader ts-node/esm --experimental-specifier-resolution=node prisma/seed.ts"
	}
}
